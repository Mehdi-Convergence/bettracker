# Database
DATABASE_URL=sqlite:///./bettracker.db

# Auth / JWT (REQUIRED — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
TRIAL_DAYS=7

# API Keys (optional — only needed for live scanner)
ODDS_API_KEY=
API_FOOTBALL_KEY=

# ML Tuning
KELLY_FRACTION=0.125
MAX_STAKE_PERCENT=0.03
MIN_EDGE_THRESHOLD=0.05
INITIAL_BANKROLL=200.0

# Strategy Config
ALLOWED_OUTCOMES=H,D,A

# ELO
ELO_K_FACTOR=32
ELO_HOME_ADVANTAGE=65
ELO_INITIAL=1500

# Data collection
FOOTBALL_DATA_BASE_URL=https://www.football-data.co.uk/mmz4281
REQUEST_DELAY_SECONDS=1.0
MAX_RETRIES=3

# Redis (optional — for shared cache in production)
REDIS_URL=

# CORS (comma-separated origins, defaults to localhost)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Email (Resend — optional, emails skipped if empty)
RESEND_API_KEY=
RESEND_FROM_EMAIL=BetTracker <noreply@bettracker.com>

# Frontend URL (for email links like password reset)
FRONTEND_URL=http://localhost:5173
